  height: 80rpx;
}
.u-button--primary.data-v-d420e590 {
  background: linear-gradient(45deg, #febc22, #fa8208);
  border: 0 !important;
  background-color: transparent;
}
.u-button--primary .u-button__text.data-v-d420e590 {
  font-size: 36rpx !important;
  letter-spacing: 10rpx;
}
