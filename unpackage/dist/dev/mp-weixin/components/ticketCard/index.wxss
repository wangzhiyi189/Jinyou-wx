.ticket-card .time-row.data-v-9828ffe1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.ticket-card .time-row .start-time.data-v-9828ffe1 {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}
.ticket-card .time-row .arrive-time.data-v-9828ffe1 {
  font-size: 32rpx;
  color: #666;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.ticket-card .station-row.data-v-9828ffe1 {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.ticket-card .station-row span.data-v-9828ffe1 {
  color: #999999;
}
.ticket-card .info-row.data-v-9828ffe1 {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  /* 余票状态颜色 */
}
.ticket-card .info-row .price.data-v-9828ffe1 {
  color: #fa3534;
}
.ticket-card .info-row .price .value.data-v-9828ffe1 {
  font-size: 40rpx;
}
.ticket-card .info-row .price .unit.data-v-9828ffe1 {
  font-size: 28rpx;
}
.ticket-card .info-row .stock.data-v-9828ffe1 {
  font-size: 28rpx;
}
.ticket-card .info-row .stock-normal.data-v-9828ffe1 {
  color: #333;
}
.ticket-card .info-row .stock-warning.data-v-9828ffe1 {
  color: #FF7D00;
}
.ticket-card .info-row .stock-danger.data-v-9828ffe1 {
  color: #FF4D4F;
}
.ticket-card.data-v-9828ffe1:active {
  transform: scale(0.98);
}

/* 禁用/无票状态 */
.ticket-card.disabled.data-v-9828ffe1 {
  opacity: 0.5;
  pointer-events: none;
}