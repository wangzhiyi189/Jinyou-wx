/* 文章场景相关 */
 .uni-tabbar-bottom .uni-tabbar__icon {
  width: 48px;
  height: 38px;
}
.pax-head {
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  font-size: 28rpx;
}
.pax-head .head-title {
  font-weight: 600;
  font-size: 32rpx;
}
.pax-head .head-close {
  color: #666;
}
.pax-head .head-submit {
  color: orange;
}
.pax-module {
  padding: 30rpx;
  background-color: #f5f5f5;
  max-height: 500rpx;
  overflow-x: auto;
}
.pax-module .main {
  background-color: #fff;
  border-radius: 10rpx;
}
.pax-module .main .add {
  display: flex;
  align-items: center;
  gap: 10rpx;
  justify-content: center;
  color: #2979ff;
  font-size: 28rpx;
  border-bottom: 1px solid #f0e5e5;
  padding: 30rpx;
}
.pax-module .main .add .u-icon .u-icon__icon {
  color: orange !important;
  font-size: 36rpx !important;
}
.pax-module .main .list {
  padding: 30rpx;
}

/* ========== ✅ 修复后的正确样式 ========== */
/* 1. 直接命中你给组件加的 passeng-checkbox 类 */
.passeng-checkbox {
  width: 100%;
  padding: 10rpx 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.u-checkbox__label-wrap {
  width: 100%;
  flex-shrink: 0;
  margin-right: 20rpx;
}

/* 3. 直接写你自定义的 address-info 样式，不依赖组件内部 */
.address-info {
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.address-info .info-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.address-info .info-head .info-title {
  font-size: 28rpx;
  color: #333333;
}
.address-info .info-head .edit .u-icon {
  color: #2979ff !important;
  font-size: 40rpx !important;
}
.address-info .info-text {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #666;
  font-size: 24rpx;
}