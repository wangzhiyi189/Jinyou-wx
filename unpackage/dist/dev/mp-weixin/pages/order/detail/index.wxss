 .uni-tabbar-bottom .uni-tabbar__icon {
  width: 48px;
  height: 38px;
}
.detail {
  height: 100vh;
  overflow: auto;
  display: flex;
  flex-direction: column;
  gap: 0;
  background-color: #f5f5f5;
}
.detail .detail-head {
  background-color: #2979ff;
  height: 350rpx;
  padding: 30rpx;
  color: #fff;
}
.detail .detail-head .head-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.detail .detail-head .head-info .info-icon .u-icon .u-icon__icon {
  font-size: 60rpx !important;
  color: #fff !important;
}
.detail .detail-head .head-info .info-content .content-text {
  font-size: 40rpx;
  font-weight: 600;
}
.detail .detail-head .head-info .info-content .content-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  align-items: center;
}
.detail .detail-head .head-info .info-content .content-desc .u-count-down .u-count-down__text {
  font-size: 24rpx;
  color: #fff;
}
.detail .order-main {
  margin-top: -250rpx;
  position: relative;
  padding: 20rpx;
  overflow-y: auto;
  box-sizing: border-box;
  padding-bottom: 140rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.detail .order-main .order-card {
  margin: 0;
  padding: 0;
}
.detail .order-main .order-card .order-card_info {
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 40rpx;
  padding-bottom: 0;
}
.detail .order-main .order-card .order-card_info .info-departtime {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  align-items: center;
}
.detail .order-main .order-card .order-card_info .info-departtime .date {
  font-size: 40rpx;
  font-weight: 600;
}
.detail .order-main .order-card .order-card_info .info-departtime .price {
  color: #f53f3f;
  font-size: 36rpx;
}
.detail .order-main .order-card .order-card_info .info-stationinfo {
  display: flex;
  gap: 30rpx;
  justify-content: space-between;
  align-items: center;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .stationinfo {
  padding: 30rpx 0;
  font-size: 32rpx;
  color: #333333;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .stationinfo .upstation {
  padding-left: 40rpx;
  padding-bottom: 40rpx;
  position: relative;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .stationinfo .downstation {
  padding-left: 40rpx;
  position: relative;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .stationinfo .upstation::before {
  content: "";
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ff9000;
  position: absolute;
  left: 0;
  top: 16rpx;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .stationinfo .upstation::after {
  content: "";
  width: 1rpx;
  height: 100%;
  background: #f4f6fa;
  position: absolute;
  left: 8rpx;
  top: 40rpx;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .stationinfo .downstation::before {
  content: "";
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #00d09b;
  margin-top: -6rpx;
  position: absolute;
  left: 0;
  top: 50%;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .line {
  font-size: 26rpx;
  display: flex;
  align-items: center;
  gap: 0;
  min-width: 50rpx;
  color: #2979ff;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .line .u-icon {
  margin-top: 2rpx;
}
.detail .order-main .order-card .order-card_info .info-stationinfo .line .u-icon .u-icon__icon {
  color: #2979ff !important;
}
.detail .order-main .order-card .order-card_info .info-otherinfo {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999999;
}
.detail .order-main .order-card .order-card_info .info-otherinfo .otherinfo-item {
  display: flex;
  align-items: center;
  gap: 5rpx;
}
.detail .order-main .order-card .order-card_info .info-otherinfo .otherinfo-item .u-icon {
  margin-top: 2rpx;
}
.detail .order-main .order-card .order-card_info .info-otherinfo .otherinfo-item .u-icon .u-icon__icon {
  color: #999999 !important;
}
.detail .order-main .order-card .order-card_hr {
  width: 100%;
  height: 40rpx;
}
.detail .order-main .order-card .order-card_hr .hr {
  width: 100%;
  height: 100%;
}
.detail .order-main .order-card .scheduletips {
  background-color: #fff;
  border-radius: 0 0 20rpx 20rpx;
  padding: 20rpx 40rpx;
  padding-top: 0;
}
.detail .order-main .order-card .scheduletips .tiplist {
  width: 100%;
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  align-items: center;
}
.detail .order-main .order-card .scheduletips .tiplist .tiplist-item {
  display: flex;
  align-items: center;
  gap: 3rpx;
  font-size: 26rpx;
  color: #666;
}
.detail .order-main .order-card .scheduletips .tiplist .tiplist-item .u-icon {
  margin-top: 5rpx;
}
.detail .order-main .order-card .scheduletips .tiplist .tiplist-item .u-icon .u-icon__icon {
  font-size: 28rpx !important;
  color: #666 !important;
}
.detail .order-main .order-card .scheduletips .btn {
  color: #2979ff;
  font-size: 26rpx;
}
.detail .order-main .order-more {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 0 30rpx;
}
.detail .order-main .order-more .more-item {
  padding: 30rpx 0;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0e5e5;
}
.detail .order-main .order-more .more-item .item-label {
  font-weight: 600;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.detail .order-main .order-more .more-item .item-label .icon {
  width: 40rpx;
  height: 40rpx;
}
.detail .order-main .order-more .more-item .item-value {
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
  gap: 5rpx;
}
.detail .order-main .order-more .more-item:last-of-type {
  border: 0;
}
.detail .oreder-btn {
  width: 100%;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  position: fixed;
  bottom: 0;
  background-color: #fff;
}
.detail .oreder-btn .btn-flex {
  display: flex;
  gap: 30rpx;
  justify-content: space-between;
  align-items: center;
}
.detail .oreder-btn .u-button {
  max-width: 80%;
  border-radius: 50rpx;
  height: 70rpx;
  font-size: 26rpx;
}