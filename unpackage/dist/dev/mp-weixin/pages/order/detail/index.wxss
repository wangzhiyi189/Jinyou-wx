.u-button {
  height: 80rpx;
}
.u-button--primary {
  background: linear-gradient(45deg, #febc22, #fa8208);
  border: 0 !important;
  background-color: transparent;
}
.u-button--primary .u-button__text {
  font-size: 36rpx !important;
  letter-spacing: 10rpx;
}
 .uni-button:after {
  content: "";
  border: 0;
}
.u-navbar .u-status-bar, .u-navbar .u-navbar__content {
  background-color: #2979ff !important;
}
.u-navbar .u-status-bar .u-navbar__content__title, .u-navbar .u-navbar__content .u-navbar__content__title {
  color: #fff;
}
.u-checkbox__label-wrap {
  width: 100%;
  margin-right: 20rpx;
}

