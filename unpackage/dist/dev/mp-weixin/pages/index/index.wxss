  z-index: 999;
  color: #fff;
  padding-bottom: 30rpx;
}
.home .home-tap .tap-content.data-v-1cf27b2a {
  position: relative;
  display: flex;
  align-content: center;
  align-items: center;
  box-sizing: border-box;
}
.home .home-tap .tap-content .tap-left.data-v-1cf27b2a {
  font-size: 26rpx;
}
.home .home-tap .tap-content .tap-title.data-v-1cf27b2a {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
}
.home .home-swiper.data-v-1cf27b2a {
  height: 560rpx;
  position: relative;
}
.home .home-swiper.data-v-1cf27b2a::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: -40rpx;
  height: 60rpx;
  z-index: 10;
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  background: linear-gradient(to top, #fff 0%, transparent 100%);
  pointer-events: none;
}
